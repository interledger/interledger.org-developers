# Linear API credentials (required for sync functions)
LINEAR_API_KEY=
# Custom view ID — overrides the default hardcoded in build-snapshot.ts
# LINEAR_CUSTOM_VIEW_ID=27df73bc-50ec-4fc1-bbb2-d906236a5bbc

# Bearer token for POST /api/sync (manual sync trigger)
API_SECRET=

# Netlify Personal Access Token — used by sync functions to purge CDN cache
# Get from: Netlify UI → User Settings → Applications → Personal access tokens
NETLIFY_API_TOKEN=

# Site ID is auto-injected by netlify dev after `netlify link`
# NETLIFY_SITE_ID=
